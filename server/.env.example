# MongoDB Connection (encode @ in password as %40)
MONGODB_URI=
# JWT Secret (generate a long random string for production)
JWT_SECRET=

# Server
PORT=5000

# Set to "production" when deploying (enables serving the React build from Express)
NODE_ENV=development

# Frontend URL used for CORS (in production set this to your deployed app URL)
FRONTEND_URL=http://localhost:5173
